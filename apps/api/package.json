{
  "name": "@cafe/api",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --test -r ts-node/register \"test/**/*.ts\"",
    "start": "npm run build:ts && fastify start -l info -p ${PORT:-4040} -a 0.0.0.0 dist/app.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -p ${PORT:-4040} -a 0.0.0.0 dist/app.js"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@cafe/core": "workspace:*",
    "@cafe/db": "workspace:*",
    "@fastify/autoload": "6.3.1",
    "@fastify/sensible": "6.0.4",
    "fastify": "5.8.5",
    "fastify-cli": "8.0.0",
    "fastify-plugin": "6.0.0",
    "fastify-raw-body": "^5.0.0",
    "stripe": "^22.2.1",
    "svix": "^1.95.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "11.0.0",
    "concurrently": "10.0.3",
    "fastify-tsconfig": "3.0.0",
    "ts-node": "10.9.2",
    "typescript": "^5.7.3"
  }
}
