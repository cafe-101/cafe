// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "tenant"]
}

// -----------------------------------------------------------------------------
// CORE TENANT MODEL
// -----------------------------------------------------------------------------

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users           User[]
  menuCategories  MenuCategory[]
  menuItems       MenuItem[]
  orders          Order[]
  orderItems      OrderItem[]
  inventoryItems  InventoryItem[]
  promotions      Promotion[]

  @@schema("public")
}

// -----------------------------------------------------------------------------
// USERS & STAFF
// -----------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  STORE_MANAGER
  STAFF
  @@schema("public")
}

model User {
  id         String   @id @default(cuid())
  supabaseId String?  @unique // Tied to Supabase authentication
  email      String   @unique
  name       String?
  role       Role     @default(STAFF)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Multi-tenant (Super Admins might have storeId = null)
  storeId  String?
  store    Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@schema("public")
}

// -----------------------------------------------------------------------------
// MENU & PRODUCTS
// -----------------------------------------------------------------------------

model MenuCategory {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId  String
  store    Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])

  items     MenuItem[]

  @@schema("tenant")
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int      // Stored in cents (e.g., $10.00 = 1000)
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])

  storeId    String
  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([categoryId])

  orderItems  OrderItem[]

  @@schema("tenant")
}

// -----------------------------------------------------------------------------
// ORDERS & TRANSACTIONS
// -----------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
  @@schema("tenant")
}

model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PENDING)
  totalAmount Int         // Stored in cents
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  storeId    String
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])

  items       OrderItem[]

  @@schema("tenant")
}

model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  unitPrice  Int      // Price at time of order
  createdAt  DateTime @default(now())

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@schema("tenant")
}

// -----------------------------------------------------------------------------
// INVENTORY
// -----------------------------------------------------------------------------

model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  quantity  Int
  unit      String   // e.g., 'kg', 'liters', 'pieces'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId  String
  store    Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@schema("tenant")
}

// -----------------------------------------------------------------------------
// PROMOTIONS & OFFERS
// -----------------------------------------------------------------------------

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  BOGO
  @@schema("tenant")
}

model Promotion {
  id           String       @id @default(cuid())
  code         String
  description  String?
  discountType DiscountType
  discountValue Int         // E.g., 10 for 10%, or 500 for $5.00
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  storeId     String
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@unique([code, storeId])
  @@schema("tenant")
}

// -----------------------------------------------------------------------------
// AUDIT LOGGING
// -----------------------------------------------------------------------------

enum AuditAction {
  SIGN_UP
  SIGN_IN
  SIGN_OUT
  PURCHASE
  CANCELLATION
  COUPON_USAGE
  OTHER
  @@schema("public")
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entityId    String?     // ID of the affected entity (Order, User, etc)
  entityType  String?     // Type of the affected entity
  userId      String?     // User who performed the action
  storeId     String?     // Branch context
  ipAddress   String?     // IP address of the request
  deviceInfo  String?     // User-Agent or device details
  metadata    Json?       // Flexible JSON for before/after states or context
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([storeId])
  @@index([action])
  @@schema("public")
}
